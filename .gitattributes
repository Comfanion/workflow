# Normalize line endings across contributors (macOS / Linux / Windows).
# Without this, contributors on different OSes introduce whitespace churn that
# pollutes diffs and breaks YAML/JSON checks in CI.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# SVG is XML text — keep it normalized.
*.svg text

# Exclude macOS/Windows noise from source archives (still gitignored, but this
# keeps `git archive` tarballs clean too).
.DS_Store export-ignore
Thumbs.db export-ignore
